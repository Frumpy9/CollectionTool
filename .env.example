# Production Docker / Cloudflare Tunnel settings.
# Local development with `npm run dev` works without copying this file.
NODE_ENV=production
APP_URL=https://your-domain.example
SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-chars
DATABASE_PATH=/data/collection.sqlite
UPLOADS_PATH=/data/uploads
PORT=7317
MAX_IMAGE_UPLOAD_BYTES=6291456

PSA_USERNAME=
PSA_PASSWORD=
PSA_ACCESS_TOKEN=

POKEMONTCG_API_KEY=
POKEMON_PRICE_TRACKER_API_KEY=

ENABLE_SCHEDULED_PRICE_REFRESH=true
PRICE_REFRESH_INTERVAL_HOURS=12
PRICE_REFRESH_BATCH_SIZE=10

ENABLE_CGC_LOOKUP=true
ENABLE_SCHEDULED_BACKUPS=true
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30
