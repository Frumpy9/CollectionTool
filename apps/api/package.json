{
  "name": "@collection-tool/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsc -p tsconfig.json && DATABASE_PATH=../../data/collection.sqlite UPLOADS_PATH=../../data/uploads node dist/server.js",
    "dev:watch": "tsx watch src/server.ts",
    "seed:dev-admin": "tsc -p tsconfig.json && DATABASE_PATH=../../data/collection.sqlite node dist/scripts/seedDevAdmin.js",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@collection-tool/shared": "file:../../packages/shared",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
